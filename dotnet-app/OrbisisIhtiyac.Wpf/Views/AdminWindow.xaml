<Window x:Class="OrbisisIhtiyac.Wpf.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin paneli"
        Height="620" Width="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Border Background="{StaticResource CardBrush}" CornerRadius="18" Padding="14" BorderBrush="#3B4A65" BorderThickness="1">
            <TabControl>
                <TabItem Header="Şifre değiştir">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="PwError" Foreground="#F87171" Margin="0,0,0,10"/>
                        <TextBlock Text="Mevcut parola" Foreground="{StaticResource MutedBrush}"/>
                        <PasswordBox x:Name="CurrentPw" Height="34" Margin="0,6,0,12"/>
                        <TextBlock Text="Yeni parola (en az 4 karakter)" Foreground="{StaticResource MutedBrush}"/>
                        <PasswordBox x:Name="NewPw" Height="34" Margin="0,6,0,12"/>
                        <Button Content="Parolayı güncelle" Style="{StaticResource PrimaryButton}" Click="OnChangePasswordClick" Width="180"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Rol yönetimi">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Kullanıcıların hangi kata ait olduğunu buradan atayabilirsiniz." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
                        <DataGrid Grid.Row="1"
                                  x:Name="UsersGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  Background="{StaticResource BgBrush}"
                                  Foreground="{StaticResource TextBrush}"
                                  GridLinesVisibility="None"
                                  RowBackground="#0F172A"
                                  AlternatingRowBackground="#111C33">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Kullanıcı" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Rol" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBlock Text="Admin" Foreground="{StaticResource MutedBrush}" Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                <ComboBox ItemsSource="{Binding RoleOptions}"
                                                          SelectedValue="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Key"
                                                          DisplayMemberPath="Value"
                                                          Visibility="{Binding IsAdmin, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"
                                                          SelectionChanged="OnRoleChanged"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>

