<Window x:Class="OrbisisIhtiyac.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrbisisIhtiyac.Wpf"
        mc:Ignorable="d"
        Title="ORBİSİS İhtiyaç" Height="760" Width="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Margin="0" Background="Transparent">
        <Border Background="{StaticResource BgBrush}"
                CornerRadius="32"
                Margin="8"
                MouseLeftButtonDown="OnDragWindow">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Üst başlık (Orbisis logosu ve sayfa başlığı) -->
                <Border Grid.Row="0"
                        Background="{StaticResource CardBrush}"
                        CornerRadius="24"
                        Padding="16"
                        Margin="16,16,16,8"
                        BorderBrush="#1F2937"
                        BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo benzeri Orbisis yazısı -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="ORBİSİS"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#3B82F6"/>
                </StackPanel>

                <!-- Kullanıcı / admin info -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="AdminButton" Content="Admin" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnAdminClick"/>
                    <Button Content="Çıkış" Style="{StaticResource SecondaryButton}" Click="OnLogoutClick"/>
                </StackPanel>

                <!-- Sayfa başlığı + kullanıcı alt başlığı -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                    <TextBlock Text="Ofis Malzemeleri" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="UserSubtitle" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                </StackPanel>
            </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="16,0,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

            <!-- Top card -->
                    <Border Grid.Row="0" Background="{StaticResource CardBrush}" CornerRadius="18" Padding="14" BorderBrush="#3B4A65" BorderThickness="1" Margin="0,0,0,10">
                        <StackPanel>
                    <!-- Location tabs -->
                    <StackPanel x:Name="LocationTabs" Orientation="Horizontal" Margin="0,0,0,10">
                        <ToggleButton x:Name="LocGenel" Content="Genel" Style="{StaticResource PillToggle}" Margin="0,0,8,0" Click="OnLocationClick"/>
                        <ToggleButton x:Name="Loc3" Content="3. kat" Style="{StaticResource PillToggle}" Margin="0,0,8,0" Click="OnLocationClick"/>
                        <ToggleButton x:Name="Loc6" Content="6. kat" Style="{StaticResource PillToggle}" Click="OnLocationClick"/>
                    </StackPanel>
                    <TextBlock x:Name="LocationTitle" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10" Visibility="Collapsed"/>

                    <!-- Needed/Bought tabs -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ToggleButton x:Name="TabNeeded" Content="İhtiyaçlar" Style="{StaticResource PillToggle}" Margin="0,0,8,0" Click="OnTabClick"/>
                        <ToggleButton x:Name="TabBought" Content="Alınanlar" Style="{StaticResource PillToggle}" Click="OnTabClick"/>
                    </StackPanel>

                    <!-- Add item -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="NewItemName" Width="260" Height="34" Margin="0,0,8,0" />
                        <TextBox x:Name="NewItemQty" Width="70" Height="34" Margin="0,0,8,0" Text="1"/>
                        <Button Content="Ekle" Style="{StaticResource PrimaryButton}" Click="OnAddItemClick"/>
                    </StackPanel>

                    <!-- Selection row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="SelectAll" Content="Tümünü seç" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Click="OnSelectAllClick"/>
                        <Button x:Name="DeleteSelectedBtn" Content="Seçilenleri sil" Style="{StaticResource DangerButton}" Margin="12,0,0,0" Click="OnDeleteSelectedClick"/>
                    </StackPanel>
                        </StackPanel>
                    </Border>

            <!-- List -->
                    <Border Grid.Row="1" Background="Transparent" BorderBrush="#223" BorderThickness="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <ItemsControl x:Name="ItemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E60F172A" CornerRadius="12" Padding="10" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,2,10,0" VerticalAlignment="Top" Checked="OnRowSelectionChanged" Unchecked="OnRowSelectionChanged"/>

                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" />
                                                <TextBlock Text="{Binding QuantityText}" Foreground="{StaticResource MutedBrush}" Margin="10,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Meta}" Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                                            <Button Content="{Binding PrimaryActionText}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnPrimaryActionClick" />
                                            <Button Content="Sil" Style="{StaticResource DangerButton}" Click="OnDeleteItemClick"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
