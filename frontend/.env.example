# Backend API (Firebase Hosting’te yayınlarken backend adresinizi yazın; boş bırakırsanız aynı origin kullanılır)
# Örnek: https://your-backend.onrender.com
VITE_API_BASE=

# Firebase (Firebase Console > Proje ayarları > Genel > Uygulamanız)
# Bu dosyayı .env olarak kopyalayıp değerleri doldurun.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
